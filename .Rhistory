#Plot of adjusted logistic regression of smoking on cardiovascular disease incidence (controlling for sex and age)
all_cvd<-allEffects(glm_full_cvd_model)
p1<-plot(all_cvd,"smoke" ,
xlab =  "Smoking Status", ylab= "CVD Incidence",
main="Association Between Smoking and CVD")
p2<-plot(all_cvd,"female" ,
xlab =  "Sex", ylab= "CVD Incidence",
main="Association Between Sex and CVD Incidence")
p3<-plot(all_cvd,"age" ,
xlab =  "Age", ylab= "CVD",
main="Association Between Age and CVD Incidence")
plot_grid(p1,p2,p3)
#Plot of adjusted logistic regression of smoking on healthcare costs (controlling for sex and age)
all_cost<-allEffects(glm_full_cost_model)
p4<-plot(all_cost,"smoke" ,
xlab =  "Smoking Status", ylab= "Healthcare Costs",
main="Association Between Smoking and Healthcare Costs")
p5<-plot(all_cost,"female" ,
xlab =  "Sex", ylab= "Healthcare Costs",
main="Association Between Sex and Healthcare Costs")
p6<-plot(all_cost,"age" ,
xlab =  "Age", ylab= "Healthcare Costs",
main="Association Between Age and Healthcare Costs")
plot_grid(p4,p5,p6)
#Plot of adjusted logistic regression of smoking on cardiovascular disease incidence (controlling for sex and age)
all_cvd<-allEffects(glm_full_cvd_model)
p1<-plot(all_cvd,"smoke" ,
xlab =  "Smoking Status", ylab= "CVD Incidence",
main="Adjusted Effect of Smoking on CVD Incidence")
p2<-plot(all_cvd,"female" ,
xlab =  "Sex", ylab= "CVD Incidence",
main="Adjusted Effect of Sex on CVD Incidence")
p3<-plot(all_cvd,"age" ,
xlab =  "Age", ylab= "CVD",
main="Adjusted Effect of Age on CVD Incidence")
plot_grid(p1,p2,p3)
